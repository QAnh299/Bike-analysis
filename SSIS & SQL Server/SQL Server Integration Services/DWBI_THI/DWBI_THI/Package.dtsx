              SQLTask:Connection="{E3A8A6CF-2415-4399-934D-7093D2FE9EDC}"
              SQLTask:SqlStatementSource="DELETE FROM Dim_Date;&#xA;&#xA;DECLARE @StartDate DATE = '2020-01-01';&#xA;DECLARE @EndDate DATE = '2022-12-31';&#xA;&#xA;WHILE @StartDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO Dim_Date&#xA;    (date_id, full_date, [day], [month], quarter, [year], is_weekend, is_holiday)&#xA;    VALUES&#xA;    (&#xA;        CAST(CONVERT(VARCHAR(8), @StartDate, 112) AS INT),&#xA;        @StartDate,&#xA;        DAY(@StartDate),&#xA;        MONTH(@StartDate),&#xA;        DATEPART(QUARTER,@StartDate),&#xA;        YEAR(@StartDate),&#xA;        CASE WHEN DATEPART(WEEKDAY,@StartDate) IN (1,7) THEN 1 ELSE 0 END,&#xA;        0&#xA;    );&#xA;&#xA;    SET @StartDate = DATEADD(DAY,1,@StartDate);&#xA;END;&#xA;&#xA;                      UPDATE Dim_Date&#xA;                      SET          is_holiday = 1&#xA;                      WHERE  full_date IN ('2020-01-01', '2020-04-10', '2020-04-13', '2020-05-08', '2020-05-25', '2020-08-31', '2020-12-25', '2020-12-28', '2021-01-01', '2021-04-02', '2021-04-05', '2021-05-03', '2021-05-31', '2021-08-30', '2021-12-27', '2021-12-28', '2022-01-03', &#xA;                                        '2022-04-15', '2022-04-18', '2022-05-02', '2022-06-02', '2022-06-03', '2022-08-29', '2022-12-26', '2022-12-27');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
