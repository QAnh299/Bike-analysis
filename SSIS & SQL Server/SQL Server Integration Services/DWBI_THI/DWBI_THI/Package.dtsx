                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    CONVERT(DATE, d.full_date) AS full_date,
    s.staff_id,
    s.first_name + ' ' + s.last_name AS staff_name,
    st.store_name,
    f.total_orders,
    f.total_revenue
FROM Fact_Staff f
JOIN Dim_Staff s 
    ON f.staff_key = s.staff_key
JOIN Dim_Store st 
    ON s.store_key = st.store_key
JOIN Dim_Date d 
    ON f.date_key = d.date_key;</property>
