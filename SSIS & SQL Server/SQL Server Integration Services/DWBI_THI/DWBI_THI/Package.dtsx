                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    d.full_date,
    p.product_id,
    p.product_name,
    s.store_name,
    fs.total_orders,
    fs.total_quantity,
    fs.total_sales
FROM Fact_Sales fs
JOIN Dim_Date d 
    ON fs.date_key = d.date_key
JOIN Dim_Product p 
    ON fs.product_key = p.product_key
JOIN Dim_Store s 
    ON fs.store_key = s.store_key;</property>
